<div id="admin-content">
    <div class="container">
        <div class="row">
            <div class="col-md-10">
                <h1 class="admin-heading"><i class="fa fa-gears"></i> All Categories</h1>
            </div>
            <div class="col-md-2">
                <a class="add-new" href="/admin/add-category">add category</a>
            </div>
            <div class="col-md-12">
               <div id="categoriesTable">

               </div>
            </div>
        </div>
    </div>
</div>


<script type="text/javascript"
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="text/javascript" src="https://unpkg.com/tabulator-tables@6.3.1/dist/js/tabulator.min.js"></script>


<script>
    const tableData = <%- JSON.stringify(categories) %>;
    // console.log(tableData)
    var table = new Tabulator("#categoriesTable", {
        data: tableData,
        layout: "fitColumns",
        pagination: true,
        paginationSize: 10,
        paginationSizeSelector: [5, 10, 25, 50, 100],
        columns: [
            // { title: "ID", field: "id", width: 50 },
            { title: "S.NO", formatter: "rownum", width:100, hozAlign: "center" },
            { title: "Category Name", field: "name", headerFilter: "input" },
            // { title: "Description", field: "description", headerFilter: "input" },
            { title: "Slug", field: "slug", headerFilter: "input" },
            {
                title: "Action", formatter: function (cell, formatterParams, onRendered) {

                    const id = cell.getRow().getData()._id
                    return `<a href='/admin/update-category/${id}' class="btn btn-primary btn-sm"><i class='fa fa-edit text-white'></i></a>
                <button onclick="deleteCategory('${id}')" class="btn btn-danger btn-sm"><i class='fa fa-trash-o text-white'></i></button>`;
                }
            },
        ],
    });

    async function deleteCategory(id) {
        try {
            if (confirm("Are you sure you want to delete this category?")) {
                const response = await fetch(`/admin/delete-category/${id}`, {
                    method: 'DELETE',
                });
                if (response.ok) {
                    alert("Category deleted successfully");
                    location.reload();
                } 
                if (response.status == 400) {
                    const data = await response.json();
                    alert(data.message);
                }
            }
        } catch (error) {
            console.error("Error deleting category:", error);
            alert("An error occurred while deleting the category");
        }
    }



</script>



<%- contentFor("tabulatorCss") %>
    <link href="https://unpkg.com/tabulator-tables@6.3.1/dist/css/tabulator.min.css" rel="stylesheet">