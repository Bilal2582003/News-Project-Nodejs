<script type="text/javascript"
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script type="text/javascript" src="https://unpkg.com/tabulator-tables@6.3.1/dist/js/tabulator.min.js"></script>

<script>
    const tableData = <%- JSON.stringify(users) %>;
    // console.log(tableData)
    var table = new Tabulator("#usersTable", {
        data: tableData,
        layout: "fitColumns",
        pagination: true,
        paginationSize: 10,
        paginationSizeSelector: [5, 10, 25, 50, 100],
        columns: [
            // { title: "ID", field: "id", width: 50 },
            { title: "S.NO", formatter: "rownum", width:100, hozAlign: "center"  },
            { title: "Full Name", field: "fullname", headerFilter: "input" },
            { title: "User Name", field: "username", headerFilter: "input" },
            { title: "Role", field: "role", headerFilter: "input" },
            {
                title: "Action", formatter: function (cell, formatterParams, onRendered) {

                    const id = cell.getRow().getData()._id
                    return `<a href='/admin/update-user/${id}' class="btn btn-primary btn-sm"><i class='fa fa-edit text-white'></i></a>
                <button onclick="deleteUser('${id}')" class="btn btn-danger btn-sm"><i class='fa fa-trash-o text-white'></i></button>`;
                }
            },
        ],
    });


   async function deleteUser(id) {
        try {
            if (confirm("Are you sure you want to delete this user?")) {
                const response = await fetch(`/admin/delete-user/${id}`, {
                    method: 'DELETE',
                });
                if (response.ok) {
                    alert("User deleted successfully");
                    location.reload();
                } if(response.status == 400) {
                    const data = await response.json()

                    alert(data.message);
                }
            }
        } catch (error) {
            console.error("Error deleting user:", error);
            alert("An error occurred while deleting the user");
        }
    }

</script>


